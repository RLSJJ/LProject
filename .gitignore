# ============================================================
# Unreal Engine 5.7 — generated build artifacts (never commit)
# ============================================================
Binaries/
DerivedDataCache/
Intermediate/
Saved/

# Plugin build artifacts (for any future plugins under Plugins/)
Plugins/*/Binaries/
Plugins/*/Intermediate/

# ============================================================
# IDE / editor state
# ============================================================
.vs/
.vscode/
.idea/
*.VC.db
*.VC.opendb
*.opensdf
*.opendb
*.sdf
*.suo

# ============================================================
# Generated project files
# (recreate via right-click LProject.uproject -> Generate Visual Studio project files)
# ============================================================
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.xcodeproj
*.xcworkspace

# ============================================================
# Language tooling (machine-specific / regenerated)
# ============================================================
# Generated by UBT GenerateClangDatabase; contains absolute machine paths.
compile_commands.json
# clangd background-index cache.
.cache/
.clangd/

# Built lighting data (regenerated by the editor)
*_BuiltData.uasset

# OS noise
Thumbs.db
.DS_Store
